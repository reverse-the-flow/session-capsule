{
  "schema_version": "0.1",
  "profile_id": "local-llamacpp-capsule-gateway",
  "profile_type": "session_capsule_gateway",
  "created_at": "2026-06-18T12:00:00-05:00",
  "command": {
    "program": "py",
    "args": ["-3", "scripts/capsule_gateway.py"]
  },
  "gateway": {
    "state_dir": ".capsules",
    "endpoint_id": "local-llamacpp",
    "host": "127.0.0.1",
    "port": 8765,
    "checkpoint_mode": "hard",
    "slot": 0,
    "default_prefill": "user_default",
    "default_thread_prefix": "gateway",
    "timeout_seconds": 120,
    "max_bundle_bytes": "5GB",
    "cors_allow_origin": "http://127.0.0.1:3000"
  },
  "transport": {
    "openai_base_url": "http://127.0.0.1:8765/v1",
    "status_url": "http://127.0.0.1:8765/api/capsules/status",
    "require_status_transport": true,
    "required_capabilities": [
      "export",
      "list",
      "download",
      "raw_upload_import",
      "stored_bundle_import",
      "delete",
      "thread_id_override",
      "digest_verification",
      "bundle_policy_gate"
    ]
  },
  "security": {
    "request_auth": {
      "source": "file",
      "ref": ".capsule-gateway-token"
    },
    "bundle_signing": {
      "source": "file",
      "ref": ".capsule-signing.key",
      "key_id": "local",
      "require_on_import": true
    },
    "bundle_import_policy": {
      "preset": "signed-metadata-only",
      "disallow_plaintext": false,
      "disallow_snapshots": false,
      "require_encryption": false,
      "require_digest_index": true
    }
  },
  "notes": [
    "This is a Model Plane launch profile, not a job packet.",
    "The profile carries secret references only. It must not contain the gateway token or signing key value.",
    "Set gateway.cors_allow_origin to the exact browser origin of the Model Plane UI, or null for non-browser/CLI-only use.",
    "transport.required_capabilities lists the gateway status capabilities Model Plane must see before enabling upload/download controls.",
    "After launch, Model Plane should read transport.status_url and require the response transport object before enabling upload/download controls."
  ]
}
