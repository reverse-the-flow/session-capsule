# Open WebUI -> Session Capsules gateway
#
# If Open WebUI runs in Docker on Windows and the capsule gateway runs on the
# host, use host.docker.internal. If both processes run directly on the host,
# use http://127.0.0.1:8765/v1 instead.

ENABLE_OPENAI_API=True
OPENAI_API_BASE_URL=http://host.docker.internal:8765/v1
OPENAI_API_KEY=sk-capsule-local

# If the gateway is launched with --auth-token-file or --auth-token-env, set
# OPENAI_API_KEY to that gateway token.

# Forward Open WebUI chat/user headers so the gateway can bind requests to a
# stable thread ledger.
ENABLE_FORWARD_USER_INFO_HEADERS=True

# The capsule gateway v0 is non-streaming. Disable streaming in the Open WebUI
# model/settings layer if your Open WebUI instance enables it by default.
