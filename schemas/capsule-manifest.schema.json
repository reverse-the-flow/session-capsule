{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/session-capsules/schemas/capsule-manifest.schema.json",
  "title": "Session Capsule Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "capsule_id",
    "thread_id",
    "kind",
    "endpoint_id",
    "compatibility",
    "context",
    "storage",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "capsule_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "thread_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "soft_checkpoint",
        "user_prefill",
        "project_prefill",
        "thread_checkpoint",
        "branch_checkpoint"
      ]
    },
    "parent_capsule_id": {
      "type": ["string", "null"],
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "endpoint_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime",
        "runtime_build",
        "model_ref",
        "model_hash",
        "tokenizer_hash",
        "context_limit",
        "slot_format"
      ],
      "properties": {
        "runtime": {
          "type": "string",
          "examples": ["llama.cpp"]
        },
        "runtime_build": {
          "type": "string"
        },
        "model_ref": {
          "type": "string"
        },
        "model_hash": {
          "type": "string"
        },
        "tokenizer_hash": {
          "type": "string"
        },
        "context_limit": {
          "type": "integer",
          "minimum": 1
        },
        "slot_format": {
          "type": "string"
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "token_start",
        "token_end",
        "token_count",
        "token_digest",
        "segments"
      ],
      "properties": {
        "token_start": {
          "type": "integer",
          "minimum": 0
        },
        "token_end": {
          "type": "integer",
          "minimum": 0
        },
        "token_count": {
          "type": "integer",
          "minimum": 0
        },
        "token_digest": {
          "type": "string"
        },
        "segments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/segment"
          }
        }
      }
    },
    "prefill_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "source_ref",
        "source_digest"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "source_ref": {
          "type": "string",
          "description": "Path relative to the capsule state directory. Do not include the .capsules prefix."
        },
        "source_digest": {
          "type": "string"
        }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "snapshot_ref"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "soft",
            "server_side_handle",
            "local_file",
            "scap_bundle"
          ]
        },
        "snapshot_ref": {
          "type": ["string", "null"],
          "description": "Path relative to the capsule state directory, for example threads/THREAD/snapshots/CAPSULE.bin. Do not include the .capsules prefix."
        },
        "runtime_snapshot_ref": {
          "type": ["string", "null"],
          "description": "Runtime-visible slot save/restore filename. This may be absolute or server-specific."
        },
        "snapshot_bytes": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "snapshot_digest": {
          "type": ["string", "null"],
          "description": "Content digest metadata. V0 snapshot file paths are not content-addressed."
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sealed": {
          "type": "boolean"
        },
        "signature": {
          "type": ["string", "null"]
        },
        "encryption": {
          "type": ["string", "null"]
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pinned": {
          "type": "boolean"
        },
        "pinned_at": {
          "type": "string",
          "format": "date-time"
        },
        "unpinned_at": {
          "type": "string",
          "format": "date-time"
        },
        "snapshot_present": {
          "type": "boolean"
        },
        "snapshot_deleted_at": {
          "type": "string",
          "format": "date-time"
        },
        "snapshot_delete_reason": {
          "type": "string"
        },
        "last_restore_failed_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_restore_error": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment_id",
        "source",
        "role",
        "token_start",
        "token_end"
      ],
      "properties": {
        "segment_id": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "system",
            "user",
            "assistant",
            "tool",
            "prefill",
            "metadata"
          ]
        },
        "role": {
          "type": "string"
        },
        "token_start": {
          "type": "integer",
          "minimum": 0
        },
        "token_end": {
          "type": "integer",
          "minimum": 0
        },
        "digest": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
